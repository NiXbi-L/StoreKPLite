# Скопируйте в .env.telegram-overseas или подключите через --env-file при compose.
# Этот файл — для docker-compose.telegram-overseas.yml (бот + bridge), не для основного compose РФ.

BOT_TOKEN=
INTERNAL_TOKEN=
OWNER_ID=

# Публичный базовый URL API на РФ (со слэшем или без). Бот дергает {API_BASE_URL}/api/users/...
API_BASE_URL=https://matchwear.ru/

# Опционально: полный URL users-service, если у вас не стандартный путь /api/users
# USERS_SERVICE_URL=https://matchwear.ru/api/users

TELEGRAM_BOT_USERNAME=

# Порт публикации bridge на этом сервере (хост:контейнер). Для только localhost: BOT_API_BRIDGE_BIND=127.0.0.1:8010
# BOT_API_BRIDGE_BIND=8010
