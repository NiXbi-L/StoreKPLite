# Create React App: только переменные с префиксом REACT_APP_ попадают в сборку.

# PUBLIC_URL=/miniapp (см. Dockerfile) — префикс статики и URL Mini App в Telegram (BotFather). Это не «браузер под /miniapp».
# Браузерная версия всегда с корня домена (/). Зашли в Safari на /miniapp/ без WebApp — редирект на / (см. public/index.html).
# Обход редиректа для отладки: ?allow_miniapp_browser=1
# Локально под тем же префиксом, что в сборке: PUBLIC_URL=/miniapp

# PWA: иконки в public/applogo/Logo192.jpg и Logo512.jpg (см. src/pwa/bootstrapBrowserPwa.js).
# PWA (только вне Telegram WebView): публичный origin сайта, без хвостового /. В docker-compose подставляется из API_BASE_URL.
# Локально: совпадает с тем, откуда открываете браузерную сборку (или оставьте пустым — возьмётся window.location.origin).
# REACT_APP_PUBLIC_ORIGIN=https://matchwear.ru

# Путь HTML превью товара для шаринга (nginx location ^~ /share/catalog/). Не через /api/products.
# REACT_APP_SHARE_CATALOG_PATH=/share/catalog
